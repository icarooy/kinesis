# Variáveis de ambiente do frontend.
# Copie este arquivo para .env e ajuste os valores conforme o ambiente.

# URL base da Kinesis API (Spring Boot)
VITE_API_BASE_URL=https://api-kinesis-production.up.railway.app

# Supabase Auth (autenticação)
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-key-publica

# Mercado Pago — apenas a Public Key (chave pública) pode ficar no frontend.
# O Access Token NUNCA deve ser exposto aqui: ele fica só no backend (.env da api-kinesis).
# Use a Public Key de TESTE (começa com TEST-) para o ambiente Sandbox.
VITE_MERCADOPAGO_PUBLIC_KEY=TEST-00000000-0000-0000-0000-000000000000
